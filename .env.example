# ── LLM API Keys ──────────────────────────────────────
GOOGLE_API_KEY=AIzaSyBW2nLV3gEUUHe5ab5YUDWtf-qBzGGQqKw# ← REQUIRED: Get from https://aistudio.google.com/apikey
# OPENAI_API_KEY=sk-...         # optional — only needed if switching provider
# ANTHROPIC_API_KEY=sk-ant-...  # optional — only needed if switching provider
COHERE_API_KEY=...              # optional — only needed for Cohere re-ranking

# ── Vector Database ────────────────────────────────────
# Qdrant (local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_collection

# Pinecone (cloud, optional)
PINECONE_API_KEY=...
PINECONE_ENV=us-east-1

# ── Embedding Model ────────────────────────────────────
# Using HuggingFace BGE (free, no API key needed) as default with Google
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5   # free local model — no API key needed
EMBEDDING_PROVIDER=huggingface            # huggingface | openai

# ── LLM Settings ──────────────────────────────────────
LLM_PROVIDER=google                      # google | openai | anthropic
LLM_MODEL=gemini-2.5-flash               # gemini-1.5-flash (fast/free) | gemini-1.5-pro (better)
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── Retrieval Settings ─────────────────────────────────
RETRIEVER_K=5                            # top-k chunks to retrieve
USE_HYBRID_SEARCH=true                   # dense + BM25 sparse
USE_RERANKER=true                        # cross-encoder re-ranking
RERANKER_MODEL=rerank-english-v3.0       # Cohere reranker

# ── Chunking ───────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=recursive                 # recursive | token | semantic

# ── App ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
